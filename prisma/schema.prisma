generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid())
  username          String            @unique
  passwordHash      String
  fullName          String
  departmentId      String?
  managerId         String?
  role              Role              @default(EMPLOYEE)
  avatar            String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  approvalHistories ApprovalHistory[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  purchaseApprovals PurchaseOrder[]   @relation("POApprover")
  purchaseRequests  PurchaseOrder[]   @relation("PORequester")
  receipts          Receipt[]
  pendingApprovals  Request[]         @relation("CurrentApprover")
  requests          Request[]
  stockMovements    StockMovement[]
  department        Department?       @relation(fields: [departmentId], references: [id])
  manager           User?             @relation("UserManager", fields: [managerId], references: [id])
  subordinates      User[]            @relation("UserManager")

  @@index([role])
  @@index([departmentId])
}

model Item {
  id             String          @id @default(uuid())
  mvpp           String          @unique
  name           String
  category       String
  unit           String
  price          Decimal         @db.Decimal(15, 2)
  itemType       String          @default("VPP")
  quota          Int             @default(100)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseLines  PurchaseLine[]
  receiptLines   ReceiptLine[]
  requestLines   RequestLine[]
  substituteFor  RequestLine[]   @relation("SubstituteItem")
  stocks         Stock[]
  stockMovements StockMovement[]

  @@index([category])
  @@index([itemType])
  @@index([name])
}

model Department {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  isActive      Boolean  @default(true)
  managerUserId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  users         User[]

  @@index([code])
}

model Stock {
  id               String    @id @default(uuid())
  itemId           String
  warehouseCode    String    @default("MAIN")
  quantityOnHand   Int       @default(0)
  quantityReserved Int       @default(0)
  minQty           Int       @default(0)
  reorderPoint     Int       @default(0)
  isLocked         Boolean   @default(false)
  lastCountedAt    DateTime?
  rowVersion       Int       @default(1)
  updatedAt        DateTime  @updatedAt
  item             Item      @relation(fields: [itemId], references: [id])

  @@unique([itemId, warehouseCode])
  @@index([warehouseCode])
}

model StockMovement {
  id            String       @id @default(uuid())
  itemId        String
  warehouseCode String       @default("MAIN")
  movementType  MovementType
  qty           Int
  beforeQty     Int
  afterQty      Int
  refType       String?
  refId         String?
  refLineId     String?
  reason        String?
  createdById   String
  createdAt     DateTime     @default(now())
  createdBy     User         @relation(fields: [createdById], references: [id])
  item          Item         @relation(fields: [itemId], references: [id])

  @@index([itemId, warehouseCode])
  @@index([movementType])
  @@index([refType, refId])
  @@index([createdAt])
}

model Reservation {
  id            String   @id @default(uuid())
  itemId        String
  warehouseCode String   @default("MAIN")
  requestId     String
  lineId        String   @unique
  qty           Int
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([requestId])
  @@index([itemId, warehouseCode])
}

model Request {
  id                String            @id
  requesterId       String
  department        String
  beneficiaryDept   String?
  warehouseCode     String            @default("MAIN")
  requestType       String            @default("Định kỳ")
  priority          String            @default("Thường")
  prioritySlaHours  Int               @default(24)
  purpose           String?
  costCenter        String?
  projectCode       String?
  status            RequestStatus     @default(DRAFT)
  currentApproverId String?
  rejectReason      String?
  cancelReason      String?
  revisionReason    String?
  returnReason      String?
  rowVersion        Int               @default(1)
  printCount        Int               @default(0)
  version           Int               @default(1)
  neededByDate      DateTime?
  submittedAt       DateTime?
  managerApprovedAt DateTime?
  adminApprovedAt   DateTime?
  approvedAt        DateTime?
  issuedAt          DateTime?
  handoverAt        DateTime?
  closedAt          DateTime?
  lastPrintedAt     DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  approvalHistories ApprovalHistory[]
  attachments       Attachment[]
  notifications     Notification[]
  printLogs         PrintLog[]
  currentApprover   User?             @relation("CurrentApprover", fields: [currentApproverId], references: [id])
  requester         User              @relation(fields: [requesterId], references: [id])
  lines             RequestLine[]
  snapshots         RequestSnapshot[]

  @@index([requesterId])
  @@index([status])
  @@index([currentApproverId])
  @@index([createdAt])
  @@index([department])
  @@index([warehouseCode])
}

model RequestLine {
  id                      String     @id @default(uuid())
  requestId               String
  itemId                  String
  qtyRequested            Int
  qtyApproved             Int?
  qtyDelivered            Int        @default(0)
  backorderQty            Int        @default(0)
  unitPrice               Decimal?   @db.Decimal(15, 2)
  lineAmount              Decimal?   @db.Decimal(15, 2)
  quotaRemainingAtRequest Int?
  availableQtyAtRequest   Int?
  availableQtyAtApprove   Int?
  availableQtyAtIssue     Int?
  substituteItemId        String?
  note                    String?
  approvalNote            String?
  issueNote               String?
  status                  LineStatus @default(DRAFT)
  rowVersion              Int        @default(1)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  item                    Item       @relation(fields: [itemId], references: [id])
  request                 Request    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  substituteItem          Item?      @relation("SubstituteItem", fields: [substituteItemId], references: [id])

  @@unique([requestId, itemId])
  @@index([requestId])
  @@index([itemId])
  @@index([status])
}

model ApprovalHistory {
  id             String   @id @default(uuid())
  requestId      String
  approverId     String
  action         String
  reason         String?
  metadata       Json?
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())
  approver       User     @relation(fields: [approverId], references: [id])
  request        Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([approverId])
  @@index([createdAt])
}

model RequestSnapshot {
  id            String   @id @default(uuid())
  requestId     String
  version       Int
  snapshotJson  Json
  changedById   String
  changedReason String?
  createdAt     DateTime @default(now())
  request       Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, version])
  @@index([requestId])
}

model PrintLog {
  id         String   @id @default(uuid())
  requestId  String
  userId     String
  printType  String
  version    Int
  printCount Int
  reason     String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model AuditLog {
  id            String   @id @default(uuid())
  userId        String?
  entityType    String
  entityId      String
  action        String
  oldValues     Json?
  newValues     Json?
  correlationId String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}

model Attachment {
  id           String   @id @default(uuid())
  requestId    String
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  purpose      String
  uploadedById String
  createdAt    DateTime @default(now())
  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  requestId String?
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  request   Request? @relation(fields: [requestId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([requestId])
}

model PurchaseOrder {
  id           String         @id
  type         String         @default("PR")
  title        String?
  purpose      String?
  source       String         @default("MANUAL")
  priority     String         @default("NORMAL")
  department   String?
  requesterId  String?
  supplier     String?
  status       POStatus       @default(DRAFT)
  totalAmount  Decimal        @default(0) @db.Decimal(15, 2)
  expectedDate DateTime?
  approvedById String?
  approvedAt   DateTime?
  approvalNote String?
  rejectReason String?
  orderedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  lines        PurchaseLine[]
  approver     User?          @relation("POApprover", fields: [approvedById], references: [id])
  requester    User?          @relation("PORequester", fields: [requesterId], references: [id])
  receipts     Receipt[]

  @@index([status])
  @@index([supplier])
  @@index([requesterId])
}

model PurchaseLine {
  id           String        @id @default(uuid())
  poId         String
  itemId       String
  qtyRequested Int           @default(0)
  qtyApproved  Int?
  qtyOrdered   Int?
  qtyReceived  Int           @default(0)
  qtyDefective Int           @default(0)
  unitPrice    Decimal?      @db.Decimal(15, 2)
  lineAmount   Decimal?      @db.Decimal(15, 2)
  supplier     String?
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  item         Item          @relation(fields: [itemId], references: [id])
  po           PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)

  @@unique([poId, itemId])
  @@index([poId])
  @@index([itemId])
}

model Receipt {
  id            String         @id
  poId          String?
  warehouseCode String         @default("MAIN")
  supplier      String?
  receiverId    String
  status        ReceiptStatus  @default(PENDING)
  receiveDate   DateTime       @default(now())
  totalAmount   Decimal?       @db.Decimal(15, 2)
  note          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  po            PurchaseOrder? @relation(fields: [poId], references: [id])
  receiver      User           @relation(fields: [receiverId], references: [id])
  lines         ReceiptLine[]

  @@index([status])
  @@index([poId])
}

model ReceiptLine {
  id             String   @id @default(uuid())
  receiptId      String
  itemId         String
  purchaseLineId String?
  qtyOrdered     Int      @default(0)
  qtyDelivered   Int      @default(0)
  qtyAccepted    Int      @default(0)
  qtyDefective   Int      @default(0)
  unitPrice      Decimal? @db.Decimal(15, 2)
  lineAmount     Decimal? @db.Decimal(15, 2)
  location       String?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  item           Item     @relation(fields: [itemId], references: [id])
  receipt        Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([receiptId])
  @@index([itemId])
}

enum Role {
  EMPLOYEE
  MANAGER
  ADMIN
  WAREHOUSE
}

enum MovementType {
  ISSUE
  RECEIVE
  RESERVE
  UNRESERVE
  RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

enum RequestStatus {
  DRAFT
  PENDING_MANAGER
  PENDING_ADMIN
  RETURNED
  PARTIALLY_APPROVED
  APPROVED
  READY_TO_ISSUE
  PARTIALLY_ISSUED
  WAITING_HANDOVER
  BACKORDER
  COMPLETED
  REJECTED
  CANCELLED
  CLOSED
}

enum LineStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  READY_TO_ISSUE
  PARTIALLY_ISSUED
  SHORT_SHIPPED
  BACKORDER
  RETURNED
  SUBSTITUTED
  CLOSED
  CANCELLED
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  DELIVERING
  PARTIALLY_DELIVERED
  COMPLETED
  CANCELLED
  REJECTED
}

enum ReceiptStatus {
  PENDING
  COMPLETED
  DISCREPANCY
  CANCELLED
}
